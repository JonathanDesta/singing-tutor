{
  "name": "singing-tutor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify:pitch": "node scripts/verify-pitch.mjs",
    "verify:analysis": "esbuild src/lib/analysis.ts src/lib/formants.ts src/lib/scoring.ts --bundle --format=esm --outdir=scripts/.bundle && node scripts/verify-analysis.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "firebase": "^12.15.0",
    "pitchy": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^5.8.22",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "@firebase/util@1.15.1": true,
    "protobufjs@7.6.4": true
  }
}
